# Copier ce fichier en .env et remplir les valeurs

# Base de données PostgreSQL
DATABASE_URL=postgresql://tomatoscan:tomatoscan@localhost:5432/tomatoscan
POSTGRES_DB=tomatoscan
POSTGRES_USER=tomatoscan
POSTGRES_PASSWORD=change_me_in_production

# Clé secrète JWT — générer avec : openssl rand -hex 32
SECRET_KEY=changeme_generer_une_vraie_cle
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Compte administrateur pour POST /auth/token
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_mot_de_passe_fort

API_HOST=0.0.0.0
API_PORT=8000

# Environnement applicatif
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS — plusieurs origines séparées par des virgules, * pour tout autoriser
CORS_ORIGINS=*

# Chemin vers le checkpoint MobileNetV2 utilisé par /predict
MODEL_PATH=./models/mobilenetv2_best_20260624_161841.pt

# Chemin vers le CSV d'historique d'entraînement utilisé par /reports
REPORTS_PATH=models/historique_20260624_161841.csv
